{
  "manifest_version": 3,
  "name": "PhishFox - AI Anti-Phishing Assistant",
  "version": "1.0.0",
  "description": "🦊 PhishFox protects you from phishing sites using AI-powered analysis.",
  "permissions": [
    "activeTab",
    "storage",
    "webNavigation",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishFox - AI Anti-Phishing"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "warning.html",
        "warning.js",
        "style.css",
        "content.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}